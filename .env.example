#Database
#where PostgreSQL is running
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wms_db
POSTGRES_USER=wms_user
POSTGRES_PASSWORD=

#JWT
#Must be at least 32 characters long
JWT_SECRET=
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_DAYS=7

#URL where your React frontend is running
FRONTEND_URL=http://localhost:5173
# Folder where invoices and uploaded files are saved
FILE_STORAGE_PATH=./uploads

#Google OAuth2
#Get from console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#Flutterwave
#Get from developer.flutterwave.com
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

#Stripe
#Get from dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

#Brevo
#Get from app.brevo.com
BREVO_SMTP_USER=
BREVO_SMTP_KEY=

#SMS - Africa's Talking
#Use sandbox for development. Get API key from africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=